{
  "$schema": "http://json.schemastore.org/tsconfig",
  "display": "Update Repository Settings Action - Build Configuration",
  "extends": "@bfra.me/tsconfig",
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "assumeChangesOnlyAffectDirectDependencies": true,
    "target": "ES2022",
    "rootDir": "src",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist",
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test/**/*", "**/*.test.ts", "**/*.spec.ts"]
}
